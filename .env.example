# Copier ce fichier en .env pour l'execution locale des tests.
# En CI, ces variables sont fournies par le workflow GitHub Actions, pas par un fichier .env.

# URL de base de la plateforme testee
BASE_URL=http://localhost:8000

# Compte de test utilise par la fixture session_connectee (login mutualise)
TEST_EMAIL=eleve.test@codeunmax.fr
TEST_PASSWORD=Test1234!

# 1 = navigateur headless (CI et defaut local) ; 0 = navigateur visible pour deboguer en local
HEADLESS=1
